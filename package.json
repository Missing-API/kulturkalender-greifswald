{
  "name": "kulturkalender-greifswald",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/warm-venues.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test:coverage",
